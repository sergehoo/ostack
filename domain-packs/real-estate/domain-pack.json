{
  "$schema": "https://ostack.dev/schemas/domain-pack.schema.json",
  "schemaVersion": 1,
  "id": "real-estate",
  "name": "Immobilier — gestion locative et transactions",
  "sector": "immobilier",
  "language": "fr",
  "version": "0.1.0",
  "sources": [
    {
      "id": "engineering-best-practices",
      "title": "Pratiques d'ingénierie logicielle générales",
      "kind": "document"
    }
  ],
  "experts": [],
  "glossary": [
    {
      "term": "bien",
      "definition": "Bien immobilier géré ou commercialisé",
      "concept": "asset",
      "status": "extracted",
      "sources": [
        "engineering-best-practices"
      ]
    },
    {
      "term": "locataire",
      "definition": "Personne louant un bien",
      "concept": "customer",
      "status": "extracted",
      "sources": [
        "engineering-best-practices"
      ]
    },
    {
      "term": "bail",
      "definition": "Contrat de location",
      "concept": "contract",
      "status": "extracted",
      "sources": [
        "engineering-best-practices"
      ]
    },
    {
      "term": "état des lieux",
      "definition": "Constat contradictoire de l'état du bien",
      "concept": "document",
      "status": "extracted",
      "sources": [
        "engineering-best-practices"
      ]
    },
    {
      "term": "loyer",
      "definition": "Montant dû périodiquement",
      "concept": "transaction",
      "status": "extracted",
      "sources": [
        "engineering-best-practices"
      ]
    }
  ],
  "actors": [
    {
      "id": "gestionnaire",
      "name": "Gestionnaire",
      "roles": [
        "gérer",
        "encaisser"
      ],
      "status": "extracted",
      "sources": [
        "engineering-best-practices"
      ]
    },
    {
      "id": "locataire",
      "name": "Locataire",
      "roles": [
        "louer",
        "payer"
      ],
      "status": "extracted",
      "sources": [
        "engineering-best-practices"
      ]
    },
    {
      "id": "proprietaire",
      "name": "Propriétaire",
      "roles": [
        "mandater"
      ],
      "status": "extracted",
      "sources": [
        "engineering-best-practices"
      ]
    }
  ],
  "workflows": [
    {
      "id": "cycle-location",
      "name": "Cycle de location",
      "status": "extracted",
      "sources": [
        "engineering-best-practices"
      ],
      "steps": [
        {
          "id": "candidature",
          "name": "Candidature",
          "actor": "locataire"
        },
        {
          "id": "bail",
          "name": "Signature du bail",
          "requires": [
            "candidature"
          ]
        },
        {
          "id": "etat-des-lieux",
          "name": "État des lieux d'entrée",
          "requires": [
            "bail"
          ]
        },
        {
          "id": "quittancement",
          "name": "Quittancement",
          "requires": [
            "etat-des-lieux"
          ]
        }
      ]
    }
  ],
  "rules": [
    {
      "id": "no-key-handover-without-signed-lease",
      "statement": "Aucune remise des clés sans bail signé et état des lieux",
      "kind": "internal_rule",
      "when": {
        "action": "lease.handover"
      },
      "conditions": [
        {
          "path": "lease.signedAndInventory",
          "equals": true
        }
      ],
      "otherwise": {
        "block": true,
        "message": "Bail non signé ou état des lieux manquant"
      },
      "status": "pending_validation",
      "sources": [
        "engineering-best-practices"
      ],
      "validatedBy": []
    },
    {
      "id": "rent-receipt-issued",
      "statement": "Toute quittance est émise pour un paiement enregistré",
      "kind": "internal_rule",
      "when": {
        "action": "rent.receipt"
      },
      "conditions": [
        {
          "path": "payment.recorded",
          "equals": true
        }
      ],
      "otherwise": {
        "block": true,
        "message": "Paiement non enregistré"
      },
      "status": "pending_validation",
      "sources": [
        "engineering-best-practices"
      ],
      "validatedBy": []
    },
    {
      "id": "audit-lease-events",
      "statement": "Signatures, états des lieux et encaissements sont journalisés",
      "kind": "internal_rule",
      "when": {
        "action": "lease.event"
      },
      "conditions": [
        {
          "path": "audit.recorded",
          "equals": true
        }
      ],
      "otherwise": {
        "block": true,
        "message": "Événement de bail non journalisé"
      },
      "status": "pending_validation",
      "sources": [
        "engineering-best-practices"
      ],
      "validatedBy": []
    }
  ],
  "decisionTables": [
    {
      "id": "validation-operation",
      "name": "Niveau de validation d'une opération",
      "status": "pending_validation",
      "sources": [
        "engineering-best-practices"
      ],
      "inputs": [
        {
          "name": "montant",
          "values": [
            "faible",
            "moyen",
            "eleve"
          ]
        },
        {
          "name": "sensibilite",
          "values": [
            "standard",
            "sensible"
          ]
        }
      ],
      "rows": [
        {
          "conditions": {
            "montant": "faible",
            "sensibilite": "*"
          },
          "outcome": "automatique"
        },
        {
          "conditions": {
            "montant": "moyen",
            "sensibilite": "*"
          },
          "outcome": "responsable"
        },
        {
          "conditions": {
            "montant": "eleve",
            "sensibilite": "*"
          },
          "outcome": "direction"
        }
      ]
    }
  ],
  "kpis": [
    {
      "name": "taux-d-occupation",
      "objective": "Part des biens occupés",
      "formula": "biens_occupes / biens_total * 100",
      "dataSources": [
        "properties"
      ],
      "frequency": "monthly",
      "owner": "gestionnaire",
      "threshold": {
        "target": 95
      }
    }
  ],
  "mappings": [
    {
      "universalConcept": "customer",
      "localTerms": [
        "locataire",
        "acquéreur"
      ]
    },
    {
      "universalConcept": "asset",
      "localTerms": [
        "bien",
        "lot",
        "logement"
      ]
    },
    {
      "universalConcept": "contract",
      "localTerms": [
        "bail",
        "mandat"
      ]
    },
    {
      "universalConcept": "transaction",
      "localTerms": [
        "loyer",
        "vente",
        "caution"
      ]
    }
  ],
  "openQuestions": [
    "Quelles obligations réglementaires (encadrement des loyers, diagnostics obligatoires, dépôt de garantie, préavis) selon la juridiction ? — À SOURCER.",
    "Quels délais légaux de préavis et de restitution du dépôt s'appliquent ?"
  ]
}
