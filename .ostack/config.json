{
  "schemaVersion": 1,
  "project": {
    "id": "ostack",
    "name": "OStack",
    "root": "."
  },
  "ai": {
    "preferredProviders": [
      "ollama",
      "openai",
      "anthropic",
      "azure-openai",
      "google",
      "mistral",
      "deepseek",
      "openrouter"
    ],
    "models": {
      "openai": "gpt-5.4-mini",
      "anthropic": "claude-sonnet-4-5",
      "ollama": "qwen3"
    }
  },
  "security": {
    "defaultLevel": 1,
    "productionApproval": "always"
  },
  "knowledge": {
    "include": [
      "AGENTS.md",
      "README.md",
      "docs/**/*",
      "**/*.{md,json,yaml,yml}"
    ],
    "exclude": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      ".env*"
    ]
  },
  "quality": {
    "commands": [
      { "command": "npm", "args": ["run", "check"] },
      { "command": "npm", "args": ["test"] }
    ]
  },
  "observe": {
    "probes": [
      { "name": "api-health", "url": "http://127.0.0.1:4310/api/health", "expectStatus": 200, "maxLatencyMs": 500 }
    ]
  },
  "plugins": []
}
