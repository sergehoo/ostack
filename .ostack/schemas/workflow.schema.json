{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ostack.dev/schemas/workflow.schema.json",
  "title": "OStack Workflow",
  "type": "object",
  "required": ["id", "name", "version", "description", "steps"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/step" } }
  },
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "name", "securityLevel"],
      "properties": {
        "id": { "type": "string" }, "name": { "type": "string" }, "agent": { "type": "string" }, "command": { "type": "string" },
        "needs": { "type": "array", "items": { "type": "string" } }, "securityLevel": { "type": "integer", "minimum": 1, "maximum": 4 },
        "humanApproval": { "enum": ["always", "on-risk", "never"] }, "continueOnError": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
