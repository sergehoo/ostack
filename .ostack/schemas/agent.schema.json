{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ostack.dev/schemas/agent.schema.json",
  "title": "OStack Agent",
  "type": "object",
  "required": ["id", "name", "category", "role", "responsibilities", "limits", "tools", "qualityCriteria", "outputFormat", "defaultSecurityLevel"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 2 },
    "category": { "enum": ["product", "architecture", "ux", "engineering", "quality", "security", "operations", "documentation"] },
    "role": { "type": "string", "minLength": 10 },
    "responsibilities": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "limits": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "tools": { "type": "array", "items": { "type": "string" } },
    "qualityCriteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "outputFormat": { "type": "string" },
    "defaultSecurityLevel": { "type": "integer", "minimum": 1, "maximum": 4 }
  },
  "additionalProperties": false
}
