{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ostack.dev/schemas/intent-draft.schema.json",
  "title": "OStack Intent Draft",
  "description": "Structured draft of a feature intent, compiled deterministically into testable properties and expected evidence.",
  "type": "object",
  "required": ["schemaVersion", "id", "request", "invariants"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
    "request": { "type": "string", "minLength": 10, "maxLength": 4000 },
    "functionalIntent": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 300 }, "maxItems": 20 },
    "actors": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 100 }, "maxItems": 20 },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["id", "statement", "kind", "given", "when", "outcome"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
          "statement": { "type": "string", "minLength": 5, "maxLength": 500 },
          "kind": { "type": "string", "enum": ["prohibition", "permission", "obligation", "consistency"] },
          "given": { "type": "string", "minLength": 3, "maxLength": 500 },
          "when": { "type": "string", "minLength": 3, "maxLength": 500 },
          "outcome": { "type": "string", "minLength": 3, "maxLength": 500 },
          "auditRequired": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
