{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ostack.dev/schemas/domain-pack.schema.json",
  "title": "OStack Domain Pack",
  "description": "Versioned, sourced, expert-validated business knowledge. Every knowledge item carries a status and source references; unsourced knowledge cannot be confirmed.",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "sector", "language", "version", "sources", "experts", "glossary", "actors", "workflows", "rules", "decisionTables", "kpis", "mappings", "openQuestions"],
  "$defs": {
    "status": { "type": "string", "enum": ["extracted", "assumed", "pending_validation", "confirmed", "contested", "obsolete"] },
    "sourceIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "maxItems": 20 },
    "condition": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 200 },
        "equals": { "type": ["string", "number", "boolean"] },
        "exists": { "type": "boolean" },
        "minimum": { "type": "number" }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": ["expert", "reason", "validatedAt"],
      "properties": {
        "expert": { "type": "string", "minLength": 1, "maxLength": 100 },
        "role": { "type": "string", "maxLength": 100 },
        "reason": { "type": "string", "minLength": 1, "maxLength": 500 },
        "validatedAt": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "sector": { "type": "string", "minLength": 1, "maxLength": 100 },
    "country": { "type": "string", "minLength": 2, "maxLength": 10 },
    "language": { "type": "string", "minLength": 2, "maxLength": 10 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "kind"],
        "properties": {
          "id": { "type": "string", "minLength": 1, "maxLength": 100 },
          "title": { "type": "string", "minLength": 1, "maxLength": 300 },
          "kind": { "type": "string", "enum": ["document", "interview", "regulation", "data", "system", "expert_statement"] },
          "date": { "type": "string" },
          "uri": { "type": "string", "maxLength": 500 }
        },
        "additionalProperties": false
      }
    },
    "experts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "properties": { "name": { "type": "string", "minLength": 1 }, "role": { "type": "string", "minLength": 1 } },
        "additionalProperties": false
      }
    },
    "glossary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "definition", "status", "sources"],
        "properties": {
          "term": { "type": "string", "minLength": 1, "maxLength": 200 },
          "definition": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "concept": { "type": "string" },
          "status": { "$ref": "#/$defs/status" },
          "sources": { "$ref": "#/$defs/sourceIds" }
        },
        "additionalProperties": false
      }
    },
    "actors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "roles", "status", "sources"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "roles": { "type": "array", "items": { "type": "string" } },
          "status": { "$ref": "#/$defs/status" },
          "sources": { "$ref": "#/$defs/sourceIds" }
        },
        "additionalProperties": false
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "steps", "status", "sources"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "status": { "$ref": "#/$defs/status" },
          "sources": { "$ref": "#/$defs/sourceIds" },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "name"],
              "properties": {
                "id": { "type": "string" }, "name": { "type": "string" }, "actor": { "type": "string" },
                "requires": { "type": "array", "items": { "type": "string" } },
                "produces": { "type": "array", "items": { "type": "string" } },
                "irreversible": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "kind", "when", "conditions", "otherwise", "status", "sources", "validatedBy"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
          "statement": { "type": "string", "minLength": 5, "maxLength": 500 },
          "kind": { "type": "string", "enum": ["internal_rule", "good_practice", "recommendation", "regulatory_obligation", "contractual_requirement"] },
          "when": { "type": "object", "required": ["action"], "properties": { "action": { "type": "string", "minLength": 1 } }, "additionalProperties": false },
          "conditions": { "type": "array", "items": { "$ref": "#/$defs/condition" } },
          "otherwise": {
            "type": "object",
            "required": ["block"],
            "properties": { "block": { "type": "boolean" }, "message": { "type": "string", "maxLength": 300 } },
            "additionalProperties": false
          },
          "status": { "$ref": "#/$defs/status" },
          "sources": { "$ref": "#/$defs/sourceIds" },
          "validatedBy": { "type": "array", "items": { "$ref": "#/$defs/validation" } },
          "jurisdiction": { "type": "string", "maxLength": 20 },
          "effectiveFrom": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "decisionTables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "inputs", "rows", "status", "sources"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "$ref": "#/$defs/status" },
          "sources": { "$ref": "#/$defs/sourceIds" },
          "inputs": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "required": ["name", "values"],
              "properties": { "name": { "type": "string" }, "values": { "type": "array", "minItems": 1, "items": { "type": "string" } } },
              "additionalProperties": false
            }
          },
          "rows": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "required": ["conditions", "outcome"],
              "properties": {
                "conditions": { "type": "object", "additionalProperties": { "type": "string" } },
                "outcome": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "kpis": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "objective", "formula", "dataSources", "frequency", "owner"],
        "properties": {
          "name": { "type": "string" }, "objective": { "type": "string" }, "formula": { "type": "string" },
          "dataSources": { "type": "array", "items": { "type": "string" } },
          "frequency": { "type": "string" }, "owner": { "type": "string" },
          "threshold": {
            "type": "object", "required": ["target"],
            "properties": { "target": { "type": "number" }, "warning": { "type": "number" } },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["universalConcept", "localTerms"],
        "properties": {
          "universalConcept": { "type": "string" },
          "localTerms": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "openQuestions": { "type": "array", "items": { "type": "string", "maxLength": 300 } }
  },
  "additionalProperties": false
}
