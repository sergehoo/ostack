{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ostack.dev/schemas/change-plan.schema.json",
  "title": "OStack Change Plan",
  "type": "object",
  "required": ["schemaVersion", "id", "projectId", "description", "changes"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
    "projectId": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 10, "maxLength": 2000 },
    "changes": {
      "type": "array", "minItems": 1, "maxItems": 100,
      "items": {
        "type": "object", "required": ["path", "content"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 500 },
          "content": { "type": "string", "maxLength": 1000000 },
          "expectedBeforeHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
