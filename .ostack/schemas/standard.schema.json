{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ostack.dev/schemas/standard.schema.json",
  "title": "OStack Standard Profile",
  "description": "A versioned, testable technology standard: detection signals, verifiable rules, control commands and default quality budget. Rules are checkable statements, never hidden prompt preferences.",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "version", "detect", "rules", "controls"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "domain": { "type": "string", "enum": ["backend", "frontend", "mobile", "infrastructure", "ci-cd", "data"] },
    "detect": {
      "type": "object",
      "description": "Signals proving the profile applies to a project; at least one is required.",
      "properties": {
        "files": { "type": "array", "items": { "type": "string", "minLength": 1 }, "maxItems": 20 },
        "dependencies": { "type": "array", "items": { "type": "string", "minLength": 1 }, "maxItems": 20 }
      },
      "additionalProperties": false,
      "anyOf": [{ "required": ["files"] }, { "required": ["dependencies"] }]
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": ["id", "statement", "severity", "verifiableBy"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
          "statement": { "type": "string", "minLength": 10, "maxLength": 500 },
          "severity": { "type": "string", "enum": ["info", "low", "medium", "high", "critical"] },
          "verifiableBy": { "type": "string", "enum": ["lint", "typecheck", "test", "dependency_scan", "architecture_check", "review"] },
          "rationale": { "type": "string", "maxLength": 500 }
        },
        "additionalProperties": false
      }
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "description": "Exact commands proving compliance; executed only through the allowlisted quality runner.",
      "items": {
        "type": "object",
        "required": ["name", "command", "args"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 100 },
          "command": { "type": "string", "minLength": 1, "maxLength": 100 },
          "args": { "type": "array", "items": { "type": "string" }, "maxItems": 20 }
        },
        "additionalProperties": false
      }
    },
    "qualityBudget": {
      "type": "object",
      "properties": {
        "testCoverageMinimum": { "type": "number", "minimum": 0, "maximum": 100 },
        "criticalSecurityFindings": { "type": "integer", "minimum": 0 },
        "highSecurityFindings": { "type": "integer", "minimum": 0 },
        "p95ApiLatencyMs": { "type": "number", "exclusiveMinimum": 0 },
        "accessibilityScoreMinimum": { "type": "number", "minimum": 0, "maximum": 100 },
        "permissionTestsRequired": { "type": "boolean" },
        "rollbackRequired": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
